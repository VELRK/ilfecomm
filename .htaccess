RewriteEngine On

# ── CORS — allow Netlify & any browser origin ─────────────────
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, X-Session-ID"
</IfModule>

# Return 200 immediately for preflight OPTIONS requests
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]

# Allow direct access to uploads directory and all files in it
RewriteCond %{REQUEST_URI} ^/(site-real/)?uploads/
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^(.*)$ - [L]

# Handle service worker requests
RewriteRule ^firebase-messaging-sw\.js$ firebase-messaging-sw.php [L]

# Set proper headers for service worker
<Files "firebase-messaging-sw.php">
    Header set Content-Type "application/javascript"
    Header set Service-Worker-Allowed "/"
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</Files>

# Redirect /admin → /shopkart (ShopKart is the actual admin panel)
RewriteRule ^admin/?$ /shopkart [R=301,L]
RewriteRule ^admin/(.*)$ /shopkart/$1 [R=301,L]

# Redirect old /ilf/frontend/assets/ paths → /frontend/assets/
RewriteRule ^ilf/frontend/assets/(.*)$ /frontend/assets/$1 [R=301,L]

# Redirect old /ilf/assets/ paths → /assets/
RewriteRule ^ilf/assets/(.*)$ /assets/$1 [R=301,L]

# Serve /frontend/ and /assets/ static files directly (no CodeIgniter, no SPA fallback)
RewriteCond %{REQUEST_URI} ^/(frontend|assets|images|css|js|fonts|webfonts|uploads)/
RewriteRule ^(.*)$ - [L]

# Route PHP API (shopkart-api) to CodeIgniter
RewriteCond %{REQUEST_URI} ^/shopkart-api/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php/$1 [L]

# ShopKart admin panel and legacy /admin → CodeIgniter
RewriteCond %{REQUEST_URI} ^/(shopkart|admin)/? [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php/$1 [L]

# Route root and all SPA paths to the React frontend
RewriteRule ^$ frontend/index.html [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/(shopkart-api|shopkart|admin|uploads)/
RewriteRule ^(.*)$ frontend/index.html [L]